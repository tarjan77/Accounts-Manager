rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/customers/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/jobs/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/items/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/invoices/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/payments/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/settings/{document=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/private/{document=**} {
      allow read, write: if false;
    }

    match /publicQuotes/{quoteId} {
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.publicToken == quoteId;

      allow get: if resource.data.publicToken == quoteId
        || (request.auth != null && resource.data.ownerId == request.auth.uid);

      allow list: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow update: if (request.auth != null && resource.data.ownerId == request.auth.uid)
        || (
          resource.data.publicToken == quoteId
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(["status", "respondedAt", "updatedAt"])
          && request.resource.data.status in ["Accepted", "Declined"]
        );
    }
  }
}
